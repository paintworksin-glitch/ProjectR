# Required for app + Supabase client (set in Vercel Production + Preview)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Recommended for canonical URLs in shares / marketing / server emails
NEXT_PUBLIC_PUBLIC_SITE_URL=
# Optional alternate (used if PUBLIC_SITE not set)
NEXT_PUBLIC_SITE_URL=

# Optional — shared rate limits across serverless instances (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — listing-ai edge function URL
NEXT_PUBLIC_LISTING_AI_URL=

# Optional — Google Maps Static API for PDFs / maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional — app API hardening
CLEANUP_CRON_SECRET=

# Optional — sales inbox for plan upgrade requests
SALES_EMAIL=
