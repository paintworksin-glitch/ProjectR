# Copy to .env.local for local dev (never commit real secrets).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt

# Optional: Supabase Edge Function URL (same project as above).
# Deploy: supabase functions deploy listing-ai
# Set secret: supabase secrets set ANTHROPIC_API_KEY=sk-ant-api03-...
VITE_LISTING_AI_URL=https://your-project.supabase.co/functions/v1/listing-ai
