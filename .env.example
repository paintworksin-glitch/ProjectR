# Required for app + Supabase client (set in Vercel Production + Preview)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Recommended for canonical URLs in shares / marketing / server emails
NEXT_PUBLIC_PUBLIC_SITE_URL=
# Optional alternate (used if PUBLIC_SITE not set). Used for PDF/video QR links and watermark hostname text — set in production.
NEXT_PUBLIC_SITE_URL=

# Optional — shared rate limits across serverless instances (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — listing-ai (Supabase Edge Function). Prefer server-only:
LISTING_AI_URL=
# Alternative (exposed to browser bundle); omit if using LISTING_AI_URL only:
NEXT_PUBLIC_LISTING_AI_URL=

# Optional — Google Maps Static API for PDFs / maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional — app API hardening
CLEANUP_CRON_SECRET=

# Optional — sales inbox for plan upgrade requests
SALES_EMAIL=

# Cloudflare Stream (server: direct upload + webhooks; tokens never exposed to the client)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
# Create once via Stream watermarks API or scripts/upload-cloudflare-stream-watermark.mjs; paste uid here
CLOUDFLARE_WATERMARK_UID=
# Subdomain code from Stream dashboard (customer-<code>.cloudflarestream.com)
CLOUDFLARE_STREAM_CUSTOMER_CODE=
# Same value, exposed to the browser for the Stream player and thumbnail URLs
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_CODE=
# Webhook signing secret from Stream webhook configuration
CLOUDFLARE_STREAM_WEBHOOK_SECRET=

# Legacy Mux (replaced by Cloudflare Stream; kept for reference / rollback)
# Optional: public HTTPS URL to PNG/JPG watermark (Mux must fetch it). If unset, uses {site}/mux-watermark/northing-in.png
MUX_WATERMARK_IMAGE_URL=
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
# Optional: require ?secret= on GET /api/video/test (leave unset for open diagnostics in dev only)
VIDEO_DIAG_SECRET=
# Optional override for thumbnail CDN (default https://image.mux.com)
NEXT_PUBLIC_MUX_IMAGE_ORIGIN=

# Elevated Supabase access for video webhook + admin video routes
SUPABASE_SERVICE_ROLE_KEY=
